@startuml

class User {
    User : Login
    User : Password
    User : Email Address
    User : Phone_number
    User : Street_address
    User : City
    User : Postal_code
    User : PictureUser
}

class Consumer {
}

class Seller {
    Seller : Company_name
}

class Admin {
}

class Comment {
    Comment : idComment
    Comment : ContentComment
}

class Product {
    Product : idProduct
    Product : nameProduct
    Product : DescriptionProduct
    Product : PriceProduct
    Product : PictureProduct
}

class Category {
    Category : idCategory
    Category : libelleCategory
}

class Order {
    Order : idOrder
    Order : dateOrder
    Order : deliveryDate
    Order : deliveryAddress
}

class Basket {
    Basket : idBasket
}

class Rate {
    Rate : idRate
    Rate : rate
}

User <|-- Consumer
User <|-- Seller
User <|-- Admin

Consumer "0..*" -- "1..*" Product
(Consumer, Product) .. Comment

Consumer "0..*" -- "1..*" Product
(Consumer, Product) .. Rate

Consumer "1" -- "1" Seller
(Consumer, Seller) .. Rate

Product "*" --o "*" Category : Contains
Product "*" -- "1" Seller : Belongs

Order "*" -- "1" Consumer
Order "*" -- "1" Seller
Order "*" -- "*" Product

Basket "*" -- "*" Product
Basket "1" -- "1" Consumer

Comment "*" -- "1" Seller : Concerned

Rate "*" -- "1" Seller : Concerned
Rate "*" -- "1" Consumer : Rates

@enduml