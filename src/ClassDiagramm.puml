    ..

}

class Product {
    nameProduct
    descriptionProduct
    priceProduct
    pictureProduct
    ..
    getAverageRate()
    getComments()
    getSeller()
}

class Category {
    libelleCategory
    ..
}

class Order {
    dateOrder
